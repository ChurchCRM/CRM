{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020", "dom", "dom.iterable"],
    "sourceMap": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["jquery", "node", "react", "react-dom"],
    "typeRoots": ["./node_modules/@types", "./webpack/types"]
  },
  "exclude": [
    "node_modules",
    "src/vendor",
    "tests/vendor",
    "cypress.config.ts",
    "docker/cypress.config.ts",
    "cypress/configs/*"
  ]
}