# Deny direct HTTP access to uploaded family photos.
# Photos must be served exclusively through the authenticated API endpoint:
#   GET /api/family/{familyId}/photo
# See: GHSA-r286-h493-ppwj

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
