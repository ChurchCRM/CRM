{#
  _letter.html.twig
  -----------------
  Extends _base.html.twig.  Renders a standard church letterhead at the top of
  every page, followed by a recipient address block.

  Letterhead modes (letterhead variable):
    "graphic" – church letterhead image (bDirLetterHead system config path)
    "none"    – blank header space (for pre-printed letterhead paper)
    anything else / omitted – text letterhead built from sChurchName, etc.

  Variables expected (in addition to _base variables):
    - letterhead        (string)  : "graphic" | "none" | "" (default: text letterhead)
    - churchName        (string)  : from SystemConfig::getValue('sChurchName')
    - churchAddress     (string)  : from SystemConfig::getValue('sChurchAddress')
    - churchCity        (string)  : from SystemConfig::getValue('sChurchCity')
    - churchState       (string)  : from SystemConfig::getValue('sChurchState')
    - churchZip         (string)  : from SystemConfig::getValue('sChurchZip')
    - churchPhone       (string)  : from SystemConfig::getValue('sChurchPhone')
    - churchEmail       (string)  : from SystemConfig::getValue('sChurchEmail')
    - letterheadImage   (string)  : absolute path for graphic letterhead
    - today             (string)  : formatted date string
    - salutation        (string)  : e.g. "Dear Smith Family"
    - recipientAddress1 (string)
    - recipientAddress2 (string, optional)
    - recipientCity     (string)
    - recipientState    (string)
    - recipientZip      (string)
    - recipientCountry  (string, optional)
    - defaultCountry    (string)  : from SystemConfig::getValue('sDefaultCountry')

  Blocks:
    - letter_body : the main content area between address block and closing
    - closing     : signature block (default: sConfirmSincerely + sTaxSigner)
#}
{% extends "_base.html.twig" %}

{% block extra_style %}
    .letterhead-text { margin-bottom: 6mm; }
    .letterhead-text .church-name { font-size: 14pt; font-weight: bold; }
    .letterhead-text .church-contact { font-size: 9pt; }

    .date-line { text-align: right; margin-bottom: 4mm; }

    .recipient-block { margin-bottom: 8mm; }
    .recipient-block p { margin: 0; line-height: 5mm; }

    .letter-content { margin-top: 4mm; }

    .closing-block { margin-top: 8mm; }
    .closing-block .signature { margin-top: 8mm; }
{% endblock %}

{% block body %}
    {# ── Letterhead ─────────────────────────────────────────────────────── #}
    {% if letterhead == 'graphic' and letterheadImage %}
        <div style="text-align:center; margin-bottom:6mm;">
            <img src="{{ letterheadImage }}" style="max-width:100%; max-height:30mm;" alt="">
        </div>
    {% elseif letterhead == 'none' %}
        {# Leave blank space for pre-printed letterhead paper #}
        <div style="height:30mm;"></div>
    {% else %}
        <div class="letterhead-text">
            <div class="church-name">{{ churchName }}</div>
            <div class="church-contact">{{ churchAddress }}</div>
            <div class="church-contact">{{ churchCity }}, {{ churchState }}  {{ churchZip }}</div>
            <div class="church-contact">{{ churchPhone }}  {{ churchEmail }}</div>
        </div>
    {% endif %}

    {# ── Date ────────────────────────────────────────────────────────────── #}
    <div class="date-line">{{ today }}</div>

    {# ── Recipient address block ─────────────────────────────────────────── #}
    <div class="recipient-block">
        <p>{{ salutation }}</p>
        {% if recipientAddress1 %}<p>{{ recipientAddress1 }}</p>{% endif %}
        {% if recipientAddress2 %}<p>{{ recipientAddress2 }}</p>{% endif %}
        <p>{{ recipientCity }}, {{ recipientState }}  {{ recipientZip }}</p>
        {% if recipientCountry and recipientCountry != defaultCountry %}
            <p>{{ recipientCountry }}</p>
        {% endif %}
    </div>

    {# ── Main letter content ─────────────────────────────────────────────── #}
    <div class="letter-content">
        {% block letter_body %}{% endblock %}
    </div>

    {# ── Closing / signature ─────────────────────────────────────────────── #}
    <div class="closing-block">
        {% block closing %}
            <p>{{ confirmSincerely }},</p>
            <p class="signature">{{ taxSigner }}</p>
        {% endblock %}
    </div>
{% endblock %}
