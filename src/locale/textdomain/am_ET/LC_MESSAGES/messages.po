msgstr "የዝግጅት ምዝገባ"

#: 
msgid "Event Details"
msgstr "የዝግጅት ዝርዝር"

#: 
msgid "Event Template"
msgstr "የዝግጅት አብነት"

#: 
msgid "Event already exists. Redirecting to check-in..."
msgstr "ዝግጅቱ አስቀድሞ አለ። ወደ ምዝገባ እየተዛወረ..."

#: 
msgid "Event created. Redirecting to check-in..."
msgstr "ዝግጅቱ ተፈጥሯል። ወደ ምዝገባ እየተዛወረ..."

#: 
msgid "Event title is required."
msgstr "የዝግጅቱ ርዕስ ያስፈልጋል።"

#: 
msgid "Event type ID is required"
msgstr "የዝግጅት ዓይነት መለያ ያስፈልጋል"

#: 
msgid "Event type ID or group ID is required"
msgstr "የዝግጅት ዓይነት መለያ ወይም የቡድን መለያ ያስፈልጋል"

#: 
msgid "Event type has no date configured for yearly recurrence"
msgstr "የዝግጅት ዓይነቱ ለዓመታዊ ድግግሞሽ ቀን አልተቀናጀም"

#: 
msgid "Event type has no day-of-week configured for weekly recurrence"
msgstr "የዝግጅት ዓይነቱ ለሳምንታዊ ድግግሞሽ የሳምንት ቀን አልተቀናጀም"

#: 
msgid "Event type has no recurrence pattern configured"
msgstr "የዝግጅት ዓይነቱ ምንም የድግግሞሽ ቅርጸ አልተቀናጀም"

#: 
msgid "Event type has no valid day-of-month configured for monthly recurrence"
msgstr "የዝግጅት ዓይነቱ ለወርሃዊ ድግግሞሽ ትክክለኛ የወሩ ቀን አልተቀናጀም"

#: 
msgid "Every month on the"
msgstr "በሁሉ ወር ቁጥር"

#: 
msgid "Every week on"
msgstr "ሁሉ ሳምንት"

#: 
msgid "Every year on"
msgstr "ሁሉ ዓመት"

#: 
msgid "Everyone is checked in!"
msgstr "ሁሉም ተመዝግቧል!"

#: 
msgid "Failed to create class. Please try again."
msgstr "ክፍልን መፍጠር አልተሳካም። እባክዎ እንደገና ሞክሩ።"

#: 
msgid "Failed to create event."
msgstr "ዝግጅቱን መፍጠር አልተሳካም።"

#: 
msgid "Failed to create event. Please try again."
msgstr "ዝግጅቱን መፍጠር አልተሳካም። እባክዎ እንደገና ሞክሩ።"

#: 
msgid "Failed to delete. Please try again."
msgstr "ማጥፋት አልተሳካም። እባክዎ እንደገና ሞክሩ።"

#: 
msgid "Fastest workflow:"
msgstr "ፈጣኑ አሠራር:"

#: 
msgid "Find past events that are still active or have un-checked-out attendees"
msgstr "አሁንም ንቁ ወይም ያልወጡ ተሳታፊዎች ያሏቸው ያለፉ ዝግጅቶች ፈልግ"

#: 
msgid "Format: MM-DD (e.g. 04-12 for April 12)"
msgstr "ቅርጸ: ወር-ቀን (ለምሳሌ 04-12 ለሚያዝያ 12)"

#: 
msgid "Group Roster"
msgstr "የቡድን ዝርዝር"

#: 
msgid "How Sunday School + Events + Kiosks fit together"
msgstr "ሰንበት ትምህርት ቤት + ዝግጅቶች + ኪዮስኮች እንዴት አብረው ይሰሩ"

#: 
msgid "Invalid date for %s — expected YYYY-MM-DD"
msgstr "ለ %s ወቅታዊ ቀን አይደለም — ሚጠበቀው YYYY-MM-DD"

#: 
msgid "Invalid date format for rangeStart or rangeEnd"
msgstr "ለ rangeStart ወይም rangeEnd የቀን ቅርጸ ትክክለኛ አይደለም"

#: 
msgid "Invalid date; expected format YYYY-MM-DD"
msgstr "ትክክለኛ ያልሆነ ቀን; ሚጠበቀው ቅርጸ YYYY-MM-DD"

#: 
msgid "Invalid event type ID"
msgstr "ትክክለኛ ያልሆነ የዝግጅት ዓይነት መለያ"

#: 
msgid "Invalid yearly recurrence format; expected MM-DD (e.g. 04-12)"
msgstr "ትክክለኛ ያልሆነ ዓመታዊ ድግግሞሽ ቅርጸ; ሚጠበቀው MM-DD (ለምሳሌ 04-12)"

#: 
msgid "Just now"
msgstr "አሁን"

#: 
msgid "Leave blank to check out without recording the supervisor."
msgstr "ተቆጣጣሪ ሳይመዘገብ ለመውጣት ባዶ ያቆዩ።"

#: 
msgid "Link events to a group for Kiosk check-in functionality."
msgstr "ዝግጅቶችን ለኪዮስክ ምዝገባ ተግባር ከቡድን ጋር አስሩ።"

#: 
msgid "Linked Groups"
msgstr "የተያያዙ ቡድኖች"

#: 
msgid "Looking for stuck events..."
msgstr "የቆሙ ዝግጅቶችን እየፈለጉ..."

#: 
msgid "Manage event names, recurrence patterns, and attendance counts"
msgstr "የዝግጅት ስሞችን፣ የድግግሞሽ ቅርጾችን፣ እና የቀጠሮ ቆጠራዎችን አስተዳድር"

#: 
msgid "Missing required field: %s"
msgstr "የሚጠለቅ መስክ ጎደለ: %s"

#: 
msgid "No Events Today"
msgstr "ዛሬ ዝግጅቶች የሉም"

#: 
msgid "No Group"
msgstr "ቡድን የለም"

#: 
msgid "No active events found."
msgstr "ምንም ንቁ ዝግጅቶች አልተገኙም።"

#: 
msgid "No one has been checked in to this event yet."
msgstr "ወደዚህ ዝግጅት ምንም ሰው ገና አልተመዘገበም።"

#: 
msgid "No past events are still marked Active."
msgstr "ምንም ያለፉ ዝግጅቶች አሁንም ንቁ ምልክት ያላቸው የሉም።"

#: 
msgid "Open a class → click \"Create Today's Event\" — the event is created and linked to the class in one shot, then you land on the check-in page ready for a kiosk or walk-in attendance."
msgstr "ክፍልን ክፈት → \"የዛሬ ዝግጅት ፍጠር\" የሚለውን ጫን — ዝግጅቱ ተፈጥሮ ወዲያው ከክፍሉ ጋር ይያያዛል፣ ከዚያ ለኪዮስክ ወይም ያልተቀደሙ ምዝገባ ዝግጁ ወደ ምዝገባ ገጽ ይደርሳሉ።"

#: 
msgid "Optional Settings"
msgstr "አማራጭ ቅንብሮች"

#: 
msgid "Optional — record who is checking this person out (e.g. a parent picking up a child)."
msgstr "አማራጭ — ይህን ሰው የሚያስወጣ ማን እንደሆነ ምዝገብ (ለምሳሌ ልጁን/ሷን ሊወስድ/ልትወስደው የመጣ/ች ወላጅ)።"

#: 
msgid "Person checked out."
msgstr "ሰው ወጥቷል።"

#: 
msgid "Person is not checked in"
msgstr "ሰው አልተመዘገበም"

#: 
msgid "Person not in active class roster"
msgstr "ሰው በንቁ ክፍል ዝርዝር ውስጥ የለም"

#: 
msgid "Pin to Calendars"
msgstr "ወደ ቀን አቆጣጠሮች አስቀምጥ"

#: 
msgid "Please select a person to check in."
msgstr "እባክዎ ለምዝገባ ሰው ይምረጡ።"

#: 
msgid "Range end date must be on or after range start date."
msgstr "የክልሉ ማብቂያ ቀን ከጅምሪ ቀን በኋላ ወይም ተመሳሳይ መሆን አለበት።"

#: 
msgid "Range end must be a valid YYYY-MM-DD date."
msgstr "የክልሉ ማብቂያ ትክክለኛ YYYY-MM-DD ቀን መሆን አለበት።"

#: 
msgid "Range start must be a valid YYYY-MM-DD date."
msgstr "የክልሉ ጅምሪ ትክክለኛ YYYY-MM-DD ቀን መሆን አለበት።"

#: 
msgid "Range start must be before range end"
msgstr "የክልሉ ጅምሪ ከክልሉ ማብቂያ በፊት መሆን አለበት"

#: 
msgid "Range start must be before range end."
msgstr "የክልሉ ጅምሪ ከክልሉ ማብቂያ በፊት መሆን አለበት።"

#: 
msgid "RangeEnd must be on or after RangeStart"
msgstr "RangeEnd ከ RangeStart በኋላ ወይም ተመሳሳይ መሆን አለበት"

#: 
msgid "Recommended"
msgstr "የሚመከር"

#: 
msgid "Resetting will permanently delete:"
msgstr "ዳግም ማስጀመር በቋሚነት ያጠፋል:"

#: 
msgid "SQL Only"
msgstr "SQL ብቻ"

#: 
msgid "Save Time"
msgstr "ጊዜ ቆጥብ"

#: 
msgid "Save changes to this category name"
msgstr "ለዚህ ምድብ ስም ለውጦቹን አስቀምጥ"

#: 
msgid "Select an event type…"
msgstr "የዝግጅት ዓይነት ምረጥ…"

#: 
msgid "Skip"
msgstr "ዝለል"

#: 
msgid "Skip & Check Out"
msgstr "ዝለልና ወጣ"

#: 
msgid "Start Check-in"
msgstr "ምዝገባ ጀምር"

#: 
msgid "Starts"
msgstr "ይጀምራል"

#: 
msgid "Step 1: Create a Backup"
msgstr "ደረጃ 1: መጠባበቂያ ፍጠር"

#: 
msgid "Step 2: Reset Database"
msgstr "ደረጃ 2: ዳታቤዝ ዳግም አስጀምር"

#: 
msgid "Still Checked In"
msgstr "አሁንም ተመዝግቦ"

#: 
msgid "Stuck Events"
msgstr "የቆሙ ዝግጅቶች"

#: 
msgid "Take Attendance"
msgstr "ቀጠሮ ያዝ"

#: 
msgid "The Events module is disabled"
msgstr "የዝግጅቶች ሞዱል ተሰናክሏል"

#: 
msgid "There are no events scheduled for today"
msgstr "ለዛሬ ምንም ዝግጅቶች አልተቀለሱም"

#: 
msgid "This event is inactive."
msgstr "ይህ ዝግጅት ንቁ አይደለም።"

#: 
msgid "This page allows you to permanently erase all data in the ChurchCRM database. This action cannot be undone."
msgstr "ይህ ገጽ በ ChurchCRM ዳታቤዝ ውስጥ ሁሉም ውሂብ በቋሚነት እንዲጠፋ ያስችልዎታል። ይህ ተግባር መልስ ሊሰጠው አይችልም።"

#: 
msgid "This report lists every event whose end date has passed but which is still marked Active. Common causes: a volunteer forgot to tap 'Check Out', a kiosk lost connectivity, or the event was created and abandoned. Old events (years past) that were never deactivated also show up here. The 'Still Checked In' column shows whether anyone was left mid-check-in. Closing an event from this report checks everyone out (using the current time) and marks the event Inactive."
msgstr "ይህ ሪፖርት ማብቂያ ቀናቸው ያለፋቸው ግን አሁንም ንቁ ምልክት ያላቸው ሁሉም ዝግጅቶችን ይዘርዝራል። የተለመዱ ምክንያቶች: አንድ በጎ ፈቃደኛ 'ወጣ' ለማጫን ረሳ፣ ኪዮስክ ግንኙነቱ ተቋረጠ፣ ወይም ዝግጅቱ ተፈጥሮ ተትቷል። ሂደቱ ምንጊዜም ያልሰናከሉ ያረጁ ዝግጅቶች (ዓመታት ያለፋቸው) እዚህ ይታያሉ። 'አሁንም ተመዝግቦ' አምድ ምዝገባ ሒደት ውስጥ ያለ ሰው ምልክት ያሳያል። ዝግጅቱን ከዚህ ሪፖርት ከዘጋ (አሁን ያለውን ጊዜ ተጠቅሞ) ሁሉም ያወጣቸዋል እና ዝግጅቱን ንቁ ያልሆነ ምልክት ያደርጋል።"

#: 
msgid "This title will be used for all generated events."
msgstr "ይህ ርዕስ ለሁሉም ለተፈጠሩ ዝግጅቶች ይጠቀማል።"

#: 
msgid "Today's Events"
msgstr "የዛሬ ዝግጅቶች"

#: 
msgid "Too many occurrences (%d) — narrow the date range. Maximum allowed: %d"
msgstr "ብዙ ክስተቶች (%d) — የቀን ክልሉን ጥብ አድርግ። ከፍተኛው ፈቅዶ: %d"

#: 
msgid "Type RESET to confirm"
msgstr "ለማረጋገጥ RESET ብሎ ጻፍ"

#: 
msgid "Use the button above to create today's event in one click. It will be auto-linked to this class so a Kiosk can pull the roster."
msgstr "የዛሬ ዝግጅት ለመፍጠር ከላይ ያለውን ቁልፍ ተጠቀም። ኪዮስክ ዝርዝሩን ሊጎትት ወደዚህ ክፍል ራሱ ይያያዛል።"

#: 
msgid "Use this form to bulk-create a series of recurring events. Each event is created individually and can be edited or deleted independently after creation."
msgstr "ተደጋጋሚ ዝግጅቶች ተከታታይ ለመፍጠር ይህን ቅጽ ተጠቀም። ዝግጅቱ እያንዳንዱ ብቻ ብቻ ተፈጥሮ ከፈጠረ በኋላ ለብቻ ሊቀየር ወይም ሊሰረዝ ይችላል።"

#: 
msgid "Used as the default start time when creating events of this type."
msgstr "ከዚህ ዓይነት ዝግጅቶች ሲፈጠሩ ነባሪ ጅምሪ ጊዜ ሆኖ ያገለግላል።"

#: 
msgid "User must have Add Event permission and the Events module must be enabled"
msgstr "ተጠቃሚው ዝግጅት ማከል ፈቃድ ሊኖረው ይገባል እና የዝግጅቶች ሞዱል ንቁ መሆን አለበት"

#: 
msgid "Valid startDate and endDate are required"
msgstr "ትክክለኛ startDate እና endDate ያስፈልጋሉ"

#: 
msgid "View Event"
msgstr "ዝግጅት ይመልከቱ"

#: 
msgid "What does this find?"
msgstr "ይህ ምን ያግኛል?"

#: 
msgid "Who is bringing them in?"
msgstr "ማን ያስገባቸዋል?"

#: 
msgid "You must select a valid recurrence pattern."
msgstr "ትክክለኛ የድግግሞሽ ቅርጸ መምረጥ አለቦት።"

#: 
msgid "You must select an event type."
msgstr "የዝግጅት ዓይነት መምረጥ አለቦት።"

#: 
msgid "You must specify a date range."
msgstr "የቀን ክልል መወሰን አለቦት።"

#: 
msgid "checked in"
msgstr "ተመዝግቧል"

#: 
msgid "e.g., Sunday Worship Service"
msgstr "ለምሳሌ፡ የሰንበት አምልኮ አገልግሎት"

#: 
msgid "endDate must be after startDate"
msgstr "endDate ከ startDate በኋላ መሆን አለበት"

#: 
msgid "eventIds must be a non-empty array"
msgstr "eventIds ባዶ ያልሆነ ድርድር መሆን አለበት"

#: 
msgid "invalid recurrence type"
msgstr "ትክክለኛ ያልሆነ ድግግሞሽ ዓይነት"

#: 
msgid "personIds must be a non-empty array"
msgstr "personIds ባዶ ያልሆነ ድርድር መሆን አለበት"

#: 
msgid "to enable the reset button"
msgstr "ዳግም ማስጀምሪ ቁልፍን ለማንቃት"

#: 
msgid "A map will appear here once coordinates are saved — either auto-detected from your address or entered manually above."
msgstr "ካርታ እዚህ ይታያል አንዴ መጋጠሚያዎቹ ሲቀመጡ — ከአድራሻዎ ራሱ ወይም ከላይ ጊዜ ሰጥተው ሲያስገቡ።"

#: 
msgid "Both latitude and longitude must be provided together (or both left blank for automatic detection)."
msgstr "ኬክሮስና ኬንትሮስ ሁለቱም አብረው መሰጠት አለባቸው (ወይም ሁለቱም ለራሱ ኮዲንግ ባዶ ቢቀሩ)።"

#: 
msgid "Church information saved, but the address could not be auto-located. Please enter the latitude and longitude manually under Map Coordinates."
msgstr "የቤተ ክርስቲያን መረጃ ተቀምጧል፣ ግን አድራሻው ራሱ ሊገኝ አልቻለም። እባክዎ ኬክሮስ እና ኬንትሮስ ከካርታ መጋጠሚያዎች ስር ጊዜ ሰጥተው ያስገቡ።"

#: 
msgid "Coordinates are auto-detected from your address on save (via OpenStreetMap). You can also enter them manually below — manual values always take precedence over auto-detection. Leave both blank to let the system geocode from the address."
msgstr "መጋጠሚያዎቹ ሲቀመጡ ከአድራሻዎ ራሱ ይወሰናሉ (በ OpenStreetMap አማካኝነት)። ከዚህ ስር ጊዜ ሰጥተው ማስገባትም ይችላሉ — ጊዜ ሰጥቶ ያስገቡ ዋጋዎች ሁሌ ቅድሚያ ይሰጣቸዋል። ስርዓቱ ከአድራሻ ጂኦኮድ እንዲያደርግ ሁለቱንም ባዶ ያቆዩ።"

#: 
msgid "Latitude must be a number between -90 and 90."
msgstr "ኬክሮስ ከ-90 እስከ 90 ያለ ቁጥር መሆን አለበት።"

#: 
msgid "Longitude must be a number between -180 and 180."
msgstr "ኬንትሮስ ከ-180 እስከ 180 ያለ ቁጥር መሆን አለበት።"

#: 
msgid "Map Coordinates"
msgstr "የካርታ መጋጠሚያዎች"

#: 
msgid "Please select a group."
msgstr "እባክዎ ቡድን ይምረጡ።"

#: 
msgid "Please select a role."
msgstr "እባክዎ ሚና ይምረጡ።"

#: 
msgid "Please select both a group and a role."
msgstr "እባክዎ ቡድን እና ሚና ሁለቱንም ይምረጡ።"

#: 
msgid "Range: -180 to 180."
msgstr "ክልል: -180 እስከ 180።"

#: 
msgid "Range: -90 to 90."
msgstr "ክልል: -90 እስከ 90።"

#: 
msgid "e.g., -74.0060"
msgstr "ለምሳሌ፣ -74.0060"

#: 
msgid "e.g., 40.7128"
msgstr "ለምሳሌ፣ 40.7128"

#: 
msgid "mo"
msgstr "ወር"

#: 
msgid "mos"
msgstr "ወሮች"

#: 
msgid "yr"
msgstr "ዓ."

#: 
msgid "yrs"
msgstr "ዓ.ም"

#: 
msgid "An error occurred while deleting the family."
msgstr "ቤተሰቡን ሲሰርዙ ስህተት ተከስቷል።"

#: 
msgid "An error occurred while moving donations."
msgstr "ስጦታዎችን ሲያንቀሳቅሱ ስህተት ተከስቷል።"

#: 
msgid "At least one family member is required"
msgstr "ቢያንስ አንድ የቤተሰብ አባል ያስፈልጋል"

#: 
msgid "Back to Users"
msgstr "ወደ ተጠቃሚዎች ተመለስ"

#: 
msgid "Cannot delete a family with donation records. Contact a finance administrator."
msgstr "የስጦታ መዝገቦች ያሉት ቤተሰብ ሊሰረዝ አይችልም። የፋይናንስ አስተዳዳሪን ያናግሩ።"

#: 
msgid "Cannot move property in that direction"
msgstr "ንብረቱን ወደዚያ አቅጣጫ ማንቀሳቀስ አይቻልም"

#: 
msgid "Confirm Family Info"
msgstr "የቤተሰብ መረጃ ያረጋግጡ"

#: 
msgid "Delete failed"
msgstr "መሰረዝ አልተሳካም"

#: 
msgid "Direction must be \"up\" or \"down\""
msgstr "አቅጣጫ \"ወደ ላይ\" ወይም \"ወደ ታች\" መሆን አለበት"

#: 
msgid "Failed to move donations."
msgstr "ስጦታዎችን ማንቀሳቀስ አልተሳካም።"

#: 
msgid "Finance permission required"
msgstr "የፋይናንስ ፈቃድ ያስፈልጋል"

#: 
msgid "ForegroundColor and BackgroundColor are required."
msgstr "የፊት ቀለም እና የጀርባ ቀለም ያስፈልጋሉ።"

#: 
msgid "Group not found or has no special properties"
msgstr "ቡድኑ አልተገኘም ወይም ልዩ ባህሪያት የሉትም"

#: 
msgid "Group role not found"
msgstr "የቡድን ሚና አልተገኘም"

#: 
msgid "Invalid color format. Use hex colors like #FF0000."
msgstr "ልክ ያልሆነ የቀለም ቅርጸት። እንደ #FF0000 ያሉ ሄክስ ቀለሞችን ይጠቀሙ።"

#: 
msgid "Invalid field identifier"
msgstr "ልክ ያልሆነ የመስክ መለያ"

#: 
msgid "Invalid target family"
msgstr "ልክ ያልሆነ ዒላማ ቤተሰብ"

#: 
msgid "Log Out"
msgstr "ውጣ"

#: 
msgid "Membership not found"
msgstr "አባልነት አልተገኘም"

#: 
msgid "Password successfully changed for"
msgstr "ለ የይለፍ ቃል በተሳካ ሁኔታ ተቀይሯል"

#: 
msgid "Please review your family information below and confirm or request changes."
msgstr "ከዚህ በታች ያለውን የቤተሰብ መረጃዎን ይከልሱ እና ያረጋግጡ ወይም ለውጦችን ይጠይቁ።"

#: 
msgid "Please select a target family."
msgstr "ዒላማ ቤተሰብ ይምረጡ።"

#: 
msgid "Target family not found"
msgstr "ዒላማ ቤተሰቡ አልተገኘም"

#: 
msgid "Verify Family Info"
msgstr "የቤተሰብ መረጃ ያረጋግጡ"

#: 
msgid "Welcome"
msgstr "እንኳን ደህና መጡ"

#: 
msgid "You can review and verify your family information using the link below. If you need additional access, please contact your church administrator."
msgstr "ከዚህ በታች ያለውን ሊንክ በመጠቀም የቤተሰብ መረጃዎን መከለስ እና ማረጋገጥ ይችላሉ። ተጨማሪ መዳረሻ ካስፈለጎ፣ የቤተክርስቲያን አስተዳዳሪዎን ያናግሩ።"

#: 
msgid "You do not have permission to view this person"
msgstr "ይህን ሰው ለማየት ፈቃድ የለዎትም"

#: 
msgid "Are you sure you want to delete this event type? This cannot be undone."
msgstr "ይህን የዝግጅት አይነት ለመሰረዝ እርግጠኛ ነዎት? ይህን ድርጊት ሊቀለበስ አይችልም።"

#: 
msgid "Assign to me"
msgstr "ለእኔ ስጥ"

#: 
msgid "Assigned"
msgstr "ተሰጥቷል"

#: 
msgid "Assigned event not found"
msgstr "የተሰጠው ዝግጅት አልተገኘም"

#: 
msgid "Cannot Delete Event Type"
msgstr "የዝግጅት አይነቱ ሊሰረዝ አይችልም"

#: 
msgid "Cannot delete this event type — %d event(s) are using it. Deactivate the type instead, or reassign the events first."
msgstr "ይህን የዝግጅት አይነት ሊሰረዝ አይችልም — %d ዝግጅቶች እየተጠቀሙበት ናቸው። ይልቁንስ አይነቱን ያቁሙ፣ ወይም መጀመሪያ ዝግጅቶቹን እንደገና ይሰጡ።"

#: 
msgid "Kiosk Devices"
msgstr "የኪዮስክ መሳሪያዎች"

#: 
msgid "Kiosk device has not been accepted by an administrator"
msgstr "የኪዮስክ መሳሪያ በአስተዳዳሪ አልተቀበለም"

#: 
msgid "No active event assignment"
msgstr "ንቁ የዝግጅት ስምሪት የለም"

#: 
msgid "Online"
msgstr "ኦንላይን"

#: 
msgid "Opens a 30-second window for devices to register at:"
msgstr "መሳሪያዎች ለመመዝገብ 30 ሰከንድ መስኮት ይከፍታል:"

#: 
msgid "Pending"
msgstr "በጥበቃ ላይ"

#: 
msgid "Register New Device"
msgstr "አዲስ መሳሪያ ይመዝገቡ"

#: 
msgid "This event type is used by"
msgstr "ይህ የዝግጅት አይነት ጥቅም ላይ ውሏል"

#: 
msgid "Total Kiosks"
msgstr "ጠቅላላ ኪዮስኮች"

#: 
msgid "Upcoming Events"
msgstr "መጪ ዝግጅቶች"

#: 
msgid "event(s). Deactivate the type instead, or reassign the events first."
msgstr "ዝግጅቶች። ይልቁንስ አይነቱን ያቁሙ፣ ወይም መጀመሪያ ዝግጅቶቹን እንደገና ይሰጡ።"

#: 
msgid "Absolute http(s) URL of the church logo shown in email templates (and re-used elsewhere in the future). For best rendering across email clients, use a wide banner image at roughly a 3.5:1 aspect ratio (for example 350×100 px), PNG or JPG, served over HTTPS. Leave blank or enter an invalid value to fall back to the default ChurchCRM logo."
msgstr "በኢሜይል ቅጾች ውስጥ የሚታይ የቤተ ክርስቲያን አርማ ፍፁም http(s) URL (እና ወደፊት በሌሎች ቦታዎችም ጥቅም ላይ የሚውል)። በኢሜይል ደንበኞች ውስጥ ለተሻለ ማሳያ፣ HTTPS ላይ የቀረበ ሰፊ ሰሌዳ ምስል ከ3.5:1 ጋር ተቀራራቢ ጥምርታ ያለው (ለምሳሌ 350×100 px)፣ PNG ወይም JPG ይጠቀሙ። ወደ ነባሪ ChurchCRM አርማ ለመመለስ ባዶ ይተው ወይም ልቅ ዋጋ ያስገቡ።"

#: 
msgid "An option with that name already exists"
msgstr "በዚያ ስም ያለ አማራጭ አስቀድሞ ይገኛል"

#: 
msgid "Cannot delete the only remaining option"
msgstr "ብቸኛውን የቀረ አማራጭ መሰረዝ አይቻልም"

#: 
msgid "Clipboard not available. Please use the Download button to save your codes."
msgstr "ክሊፕቦርድ አይገኝም። ኮዶቹን ለማስቀመጥ ዝርዝር አውርድ ቁልፍን ይጠቀሙ።"

#: 
msgid "Custom Option"
msgstr "ብጁ አማራጭ"

#: 
msgid "Default Inbox Preview Text"
msgstr "ነባሪ የገቢ መልዕክት ቅድመ ዕይታ ጽሑፍ"

#: 
msgid "Email is disabled"
msgstr "ኢሜይል ተሰናክሏል"

#: 
msgid "Email is disabled. Configure email before resetting passwords, or use Change Password."
msgstr "ኢሜይል ተሰናክሏል። ይለፍ ቃሎችን ከዳግም ማስጀመርዎ በፊት ኢሜይልን ያዋቅሩ፣ ወይም ይለፍ ቃል ቀይር ይጠቀሙ።"

#: 
msgid "Email is disabled. Enable it in the Email Dashboard settings before testing."
msgstr "ኢሜይል ተሰናክሏል። ከፈተና በፊት በኢሜይል ዳሽቦርድ ቅንብሮች ውስጥ ያብሩት።"

#: 
msgid "Enter one of your backup recovery codes"
msgstr "ከምትኬ መልሶ ማግኛ ኮዶቾ አንዱን ያስገቡ"

#: 
msgid "Enter one of your backup recovery codes to access your account"
msgstr "ወደ መለያዎ ለመድረስ ከምትኬ መልሶ ማግኛ ኮዶቾ አንዱን ያስገቡ"

#: 
msgid "Existing Options"
msgstr "ያሉ አማራጮች"

#: 
msgid "Group not found for this role list"
msgstr "ለዚህ ሚና ዝርዝር አገልግሎት አልተገኘም"

#: 
msgid "Inactive status can only be toggled for the classifications list"
