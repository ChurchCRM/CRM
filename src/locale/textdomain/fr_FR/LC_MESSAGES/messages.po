msgid "Volunteer-entered headcounts, broken down by category."
msgstr "Comptages de participants saisis par les bénévoles, répartis par catégorie."

#: 
msgid "Your CSV has duplicate column names. Rename the duplicate columns (e.g. add \"(2)\" to the second one) and upload again."
msgstr "Votre CSV contient des noms de colonnes en double. Renommez les colonnes en double (par ex. ajoutez « (2) » à la seconde) et importez à nouveau."

#: 
msgid "Are you sure you want to permanently delete this donated item?"
msgstr "Êtes-vous sûr de vouloir supprimer définitivement cet article offert ?"

#: 
msgid "Are you sure you want to permanently delete this paddle number?"
msgstr "Êtes-vous sûr de vouloir supprimer définitivement ce numéro de palette ?"

#: 
msgid "Delete Donated Item"
msgstr "Supprimer l'article offert"

#: 
msgid "Delete Paddle Number"
msgstr "Supprimer le numéro de palette"

#: 
msgid "Invalid security token. Please try again."
msgstr "Jeton de sécurité invalide. Veuillez réessayer."

