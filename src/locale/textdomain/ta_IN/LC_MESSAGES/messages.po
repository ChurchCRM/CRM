#: 
msgid "Configuration"
msgstr "கட்டமைப்பு"

#: 
msgid "Continent"
msgstr "கண்டம்"

#. plugin:vonage:section:6:title
#: 
msgid "Costs"
msgstr "செலவுகள்"

#. plugin:openlp:section:0:title
#. plugin:vonage:section:0:title
#: 
msgid "Current Usage"
msgstr "தற்போதைய பயன்பாடு"

#. plugin:gravatar:section:1:title
#: 
msgid "Default Image Styles"
msgstr "இயல்புநிலை படப் பாணிகள்"

#: 
msgid "Default Map View"
msgstr "இயல்புநிலை வரைபட காட்சி"

#: 
msgid "Deposit ticket type"
msgstr "வைப்பு டிக்கெட் வகை"

