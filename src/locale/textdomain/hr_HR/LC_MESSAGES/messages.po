msgid "You are <strong>{{releaseCount}}</strong> releases behind. Here's what you'll gain:"
msgstr "Zaostajete za <strong>{{releaseCount}}</strong> izdanja. Evo što ćete dobiti:"

#: 
msgid "You are running a pre-release version."
msgstr "Pokrećete predverziju."

#: 
msgid "You can still proceed with the upgrade without viewing release notes."
msgstr "I dalje možete nastaviti s nadogradnjom bez pregledavanja bilješki o izdanju."

#: 
msgid "You're up to date!"
msgstr "Ažurni ste!"

#: 
msgid "A valid person must be selected."
msgstr "Mora se odabrati valjana osoba."

#: 
msgid "Add Donors"
msgstr "Dodaj donatore"

#: 
msgid "Add to Buyer List"
msgstr "Dodaj na popis kupaca"

#: 
msgid "Auto-assign paddle numbers to all item donors"
msgstr "Automatski dodijeli brojeve vesla svim donatorima predmeta"

#: 
msgid "Create a new user account"
msgstr "Stvori novi korisnički račun"

#: 
msgid "Delete this item?"
msgstr "Obrisati ovaj predmet?"

#: 
msgid "Delete this paddle number?"
msgstr "Obrisati ovaj broj vesla?"

#: 
msgid "Edit Buyer"
msgstr "Uredi kupca"

#: 
msgid "Login already in use, please select a different login!"
msgstr "Prijava je već u upotrebi, odaberite drugu prijavu!"

#: 
msgid "Login must be at least 3 characters!"
msgstr "Prijava mora imati najmanje 3 znaka!"

#: 
msgid "Manage Fundraisers"
msgstr "Upravljanje prikupljanjem sredstava"

#: 
msgid "New User"
msgstr "Novi korisnik"

#: 
msgid "Please select a person to create a user account for."
msgstr "Odaberite osobu za koju želite stvoriti korisnički račun."

#: 
msgid "Please select at least one buyer to generate statements."
msgstr "Odaberite najmanje jednog kupca za generiranje izvoda."

#: 
msgid "Return to Fundraiser Dashboard"
msgstr "Povratak na nadzornu ploču prikupljanja sredstava"

#: 
msgid "The selected person was not found."
msgstr "Odabrana osoba nije pronađena."

#: 
msgid "This action will automatically add paddle numbers for all item donors in this fundraiser who do not yet have a buyer number assigned."
msgstr "Ova radnja automatski će dodati brojeve vesla svim donatorima predmeta u ovom prikupljanju sredstava koji još nemaju dodijeljen broj kupca."

#: 
msgid "This person already has a user account."
msgstr "Ova osoba već ima korisnički račun."

#: 
msgid "User must be an Admin or have Manage Fundraisers permission"
msgstr "Korisnik mora biti administrator ili imati dopuštenje za upravljanje prikupljanjem sredstava"

#: 
msgid "User not found."
msgstr "Korisnik nije pronađen."

#: 
msgid "— Select a person —"
msgstr "— Odaberite osobu —"

