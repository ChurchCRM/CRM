msgstr "संडे स्कूल + कार्यक्रम + कियोस्क कैसे एक साथ काम करते हैं"

#: 
msgid "Invalid date for %s — expected YYYY-MM-DD"
msgstr "%s के लिए अमान्य तारीख — YYYY-MM-DD अपेक्षित"

#: 
msgid "Invalid date format for rangeStart or rangeEnd"
msgstr "rangeStart या rangeEnd के लिए अमान्य तारीख प्रारूप"

#: 
msgid "Invalid date format."
msgstr "अमान्य तारीख प्रारूप।"

#: 
msgid "Invalid date; expected format YYYY-MM-DD"
msgstr "अमान्य तारीख; अपेक्षित प्रारूप YYYY-MM-DD"

#: 
msgid "Invalid event type ID"
msgstr "अमान्य कार्यक्रम प्रकार ID"

#: 
msgid "Invalid yearly recurrence format; expected MM-DD (e.g. 04-12)"
msgstr "अमान्य वार्षिक पुनरावृत्ति प्रारूप; MM-DD अपेक्षित (जैसे 04-12)"

#: 
msgid "Just now"
msgstr "अभी-अभी"

#: 
msgid "Leave blank to check out without recording the supervisor."
msgstr "पर्यवेक्षक को रिकॉर्ड किए बिना चेक आउट करने के लिए खाली छोड़ें।"

#: 
msgid "Link events to a group for Kiosk check-in functionality."
msgstr "कियोस्क चेक-इन कार्यक्षमता के लिए कार्यक्रमों को एक समूह से लिंक करें।"

#: 
msgid "Linked Groups"
msgstr "लिंक किए गए समूह"

